// definições iniciais
width :: 64
type_speed_ms :: 6

//
repeat_str :: fn(c, n) { range(0, n) |> map(fn _ { c }) |> join("") }
hr :: repeat_str("-", width)

type_text :: fn(s, delay_ms) {
  chars :: string_to_list(s)
  _ :: reduce(chars, 0, fn(acc, ch) {
    print(ch)
    flush()
    sleep_ms(delay_ms)
    acc
  })
}

say :: fn(s) { type_text(s + "
", type_speed_ms) }
line :: fn(s) { println(s) }

// função para mostrar a arte ASCII do mascote
